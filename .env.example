# Supabase Configuration
# These are already hardcoded in lib/supabaseClient.ts for this project, 
# but can be moved here if you prefer using environment variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Application URL
# Set this to your Netlify URL (e.g., https://your-app-name.netlify.app)
# to ensure password reset links point to the correct site.
VITE_APP_URL=
